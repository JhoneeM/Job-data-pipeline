create table public. "Applications" (
job_id bigint generated by default as identity not null,
role text null,
company text not null,
status text null,
date_applied date null,
job_posted_date date null,
date_responded date null,
salary min bigint null,
salary max bigint null,
salary mid bigint null,
work_type text null,
city text null,
notes text null,
constraint Applications_pkey primary key (job_id)
) TABLESPACE pg_default;